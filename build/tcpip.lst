 438:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** /**
 439:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * Sends a message to TCPIP thread to call a function. Caller thread blocks on
 440:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * on a provided semaphore, which is NOT automatically signalled by TCPIP thread,
 441:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * this has to be done by the user.
 442:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * It is recommended to use LWIP_TCPIP_CORE_LOCKING since this is the way
 443:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * with least runtime overhead.
 444:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 445:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param fn function to be called from TCPIP thread
 446:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param apimsg argument to API function
 447:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param sem semaphore to wait on
 448:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @return ERR_OK if the function was called, another err_t if not
 449:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  */
 450:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** err_t
 451:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** tcpip_send_msg_wait_sem(tcpip_callback_fn fn, void *apimsg, sys_sem_t *sem)
 452:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** {
 453:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #if LWIP_TCPIP_CORE_LOCKING
 454:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   LWIP_UNUSED_ARG(sem);
