 476:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** /**
 477:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * Synchronously calls function in TCPIP thread and waits for its completion.
 478:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * It is recommended to use LWIP_TCPIP_CORE_LOCKING (preferred) or
 479:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * LWIP_NETCONN_SEM_PER_THREAD.
 480:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * If not, a semaphore is created and destroyed on every call which is usually
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccJiyNKk.s 			page 17


 481:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * an expensive/slow operation.
 482:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param fn Function to call
 483:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param call Call parameters
 484:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @return Return value from tcpip_api_call_fn
 485:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  */
 486:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** err_t
 487:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** tcpip_api_call(tcpip_api_call_fn fn, struct tcpip_api_call_data *call)
 488:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** {
 489:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #if LWIP_TCPIP_CORE_LOCKING
 490:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   err_t err;
 491:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   LOCK_TCPIP_CORE();
 492:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   err = fn(call);
 493:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   UNLOCK_TCPIP_CORE();
 494:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   return err;
 495:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #else /* LWIP_TCPIP_CORE_LOCKING */
 496:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_DECLARE(msg);
 497:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 498:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #if !LWIP_NETCONN_SEM_PER_THREAD
 499:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   err_t err = sys_sem_new(&call->sem, 0);
 500:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   if (err != ERR_OK) {
 501:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****     return err;
 502:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   }
 503:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #endif /* LWIP_NETCONN_SEM_PER_THREAD */
 504:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 505:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   LWIP_ASSERT("Invalid mbox", sys_mbox_valid_val(tcpip_mbox));
 506:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 507:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_ALLOC(msg);
 508:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_REF(msg).type = TCPIP_MSG_API_CALL;
 509:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_REF(msg).msg.api_call.arg = call;
 510:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_REF(msg).msg.api_call.function = fn;
 511:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #if LWIP_NETCONN_SEM_PER_THREAD
 512:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_REF(msg).msg.api_call.sem = LWIP_NETCONN_THREAD_SEM_GET();
 513:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #else /* LWIP_NETCONN_SEM_PER_THREAD */
 514:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_REF(msg).msg.api_call.sem = &call->sem;
 515:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #endif /* LWIP_NETCONN_SEM_PER_THREAD */
 516:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   sys_mbox_post(&tcpip_mbox, &TCPIP_MSG_VAR_REF(msg));
 517:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   sys_arch_sem_wait(TCPIP_MSG_VAR_REF(msg).msg.api_call.sem, 0);
 518:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   TCPIP_MSG_VAR_FREE(msg);
 519:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 520:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #if !LWIP_NETCONN_SEM_PER_THREAD
 521:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   sys_sem_free(&call->sem);
 522:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #endif /* LWIP_NETCONN_SEM_PER_THREAD */
 523:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 524:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   return call->err;
 525:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #endif /* LWIP_TCPIP_CORE_LOCKING */
 526:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** }
 527:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 528:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** /**
 529:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @ingroup lwip_os
 530:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * Allocate a structure for a static callback message and initialize it.
 531:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * The message has a special type such that lwIP never frees it.
 532:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * This is intended to be used to send "static" messages from interrupt context,
 533:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * e.g. the message is allocated once and posted several times from an IRQ
 534:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * using tcpip_callbackmsg_trycallback().
 535:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * Example usage: Trigger execution of an ethernet IRQ DPC routine in lwIP thread context.
 536:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 537:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param function the function to call
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccJiyNKk.s 			page 18


 538:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param ctx parameter passed to function
 539:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @return a struct pointer to pass to tcpip_callbackmsg_trycallback().
 540:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 541:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @see tcpip_callbackmsg_trycallback()
 542:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @see tcpip_callbackmsg_delete()
 543:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  */
 544:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** struct tcpip_callback_msg *
 545:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** tcpip_callbackmsg_new(tcpip_callback_fn function, void *ctx)
 546:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** {
 547:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   struct tcpip_msg *msg = (struct tcpip_msg *)memp_malloc(MEMP_TCPIP_MSG_API);
 548:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   if (msg == NULL) {
 549:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****     return NULL;
 550:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   }
 551:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   msg->type = TCPIP_MSG_CALLBACK_STATIC;
 552:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   msg->msg.cb.function = function;
 553:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   msg->msg.cb.ctx = ctx;
 554:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   return (struct tcpip_callback_msg *)msg;
 555:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** }
 556:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 557:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** /**
 558:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @ingroup lwip_os
 559:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * Free a callback message allocated by tcpip_callbackmsg_new().
 560:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 561:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param msg the message to free
 562:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 563:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @see tcpip_callbackmsg_new()
