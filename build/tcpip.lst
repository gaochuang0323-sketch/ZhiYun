ARM GAS  C:\Users\hh\AppData\Local\Temp\ccJiyNKk.s 			page 19


 595:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *         knowledge can be used to e.g. propagate "bool needs_scheduling")
 596:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 597:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @see tcpip_callbackmsg_new()
 598:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  */
 599:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** err_t
 600:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** tcpip_callbackmsg_trycallback_fromisr(struct tcpip_callback_msg *msg)
 601:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** {
 602:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   LWIP_ASSERT("Invalid mbox", sys_mbox_valid_val(tcpip_mbox));
 603:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   return sys_mbox_trypost_fromisr(&tcpip_mbox, msg);
 604:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** }
 605:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 606:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** /**
 607:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * Sends a message to TCPIP thread to call a function. Caller thread blocks
 608:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * until the function returns.
 609:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * It is recommended to use LWIP_TCPIP_CORE_LOCKING (preferred) or
 610:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * LWIP_NETCONN_SEM_PER_THREAD.
 611:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * If not, a semaphore is created and destroyed on every call which is usually
 612:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * an expensive/slow operation.
 613:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 614:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param function the function to call
 615:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param ctx parameter passed to f
 616:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @return ERR_OK if the function was called, another err_t if not
 617:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  */
 618:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** err_t
 619:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** tcpip_callback_wait(tcpip_callback_fn function, void *ctx)
 620:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** {
 621:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #if LWIP_TCPIP_CORE_LOCKING
 622:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   LOCK_TCPIP_CORE();
 623:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   function(ctx);
 624:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   UNLOCK_TCPIP_CORE();
 625:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   return ERR_OK;
 626:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #else /* LWIP_TCPIP_CORE_LOCKING */
 627:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   err_t err;
 628:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   sys_sem_t sem;
 629:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   struct tcpip_msg msg;
 630:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 631:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   LWIP_ASSERT("Invalid mbox", sys_mbox_valid_val(tcpip_mbox));
 632:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 633:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   err = sys_sem_new(&sem, 0);
 634:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   if (err != ERR_OK) {
 635:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****     return err;
 636:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   }
 637:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 638:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   msg.type = TCPIP_MSG_CALLBACK_STATIC_WAIT;
 639:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   msg.msg.cb_wait.function = function;
 640:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   msg.msg.cb_wait.ctx = ctx;
 641:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   msg.msg.cb_wait.sem = &sem;
 642:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   sys_mbox_post(&tcpip_mbox, &msg);
 643:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   sys_arch_sem_wait(&sem, 0);
 644:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   sys_sem_free(&sem);
 645:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   return ERR_OK;
 646:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #endif /* LWIP_TCPIP_CORE_LOCKING */
 647:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** }
 648:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 649:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** /**
 650:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @ingroup lwip_os
 651:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * Initialize this module:
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccJiyNKk.s 			page 20


 652:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * - initialize all sub modules
 653:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * - start the tcpip_thread
 654:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  *
 655:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param initfunc a function to call when tcpip_thread is running and finished initializing
 656:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  * @param arg argument to pass to initfunc
 657:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****  */
 658:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** void
 659:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** tcpip_init(tcpip_init_done_fn initfunc, void *arg)
 660:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** {
 661:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   lwip_init();
 662:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** 
 663:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   tcpip_init_done = initfunc;
 664:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   tcpip_init_done_arg = arg;
 665:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   if (sys_mbox_new(&tcpip_mbox, TCPIP_MBOX_SIZE) != ERR_OK) {
 666:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****     LWIP_ASSERT("failed to create tcpip_thread mbox", 0);
 667:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   }
 668:Middlewares/Third_Party/LwIP/src/api/tcpip.c **** #if LWIP_TCPIP_CORE_LOCKING
 669:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   if (sys_mutex_new(&lock_tcpip_core) != ERR_OK) {
 670:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****     LWIP_ASSERT("failed to create lock_tcpip_core", 0);
 671:Middlewares/Third_Party/LwIP/src/api/tcpip.c ****   }
