 484:LWIP/Target/ethernetif.c **** /**
 485:LWIP/Target/ethernetif.c ****  * @brief Should be called at the beginning of the program to set up the
 486:LWIP/Target/ethernetif.c ****  * network interface. It calls the function low_level_init() to do the
 487:LWIP/Target/ethernetif.c ****  * actual setup of the hardware.
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccCKtegN.s 			page 23


 488:LWIP/Target/ethernetif.c ****  *
 489:LWIP/Target/ethernetif.c ****  * This function should be passed as a parameter to netif_add().
 490:LWIP/Target/ethernetif.c ****  *
 491:LWIP/Target/ethernetif.c ****  * @param netif the lwip network interface structure for this ethernetif
 492:LWIP/Target/ethernetif.c ****  * @return ERR_OK if the loopif is initialized
 493:LWIP/Target/ethernetif.c ****  *         ERR_MEM if private data couldn't be allocated
 494:LWIP/Target/ethernetif.c ****  *         any other err_t on error
 495:LWIP/Target/ethernetif.c ****  */
 496:LWIP/Target/ethernetif.c **** err_t ethernetif_init(struct netif *netif)
 497:LWIP/Target/ethernetif.c **** {
 498:LWIP/Target/ethernetif.c ****   LWIP_ASSERT("netif != NULL", (netif != NULL));
 499:LWIP/Target/ethernetif.c **** 
 500:LWIP/Target/ethernetif.c **** #if LWIP_NETIF_HOSTNAME
 501:LWIP/Target/ethernetif.c ****   /* Initialize interface hostname */
 502:LWIP/Target/ethernetif.c ****   netif->hostname = "lwip";
 503:LWIP/Target/ethernetif.c **** #endif /* LWIP_NETIF_HOSTNAME */
 504:LWIP/Target/ethernetif.c **** 
 505:LWIP/Target/ethernetif.c ****   /*
 506:LWIP/Target/ethernetif.c ****    * Initialize the snmp variables and counters inside the struct netif.
 507:LWIP/Target/ethernetif.c ****    * The last argument should be replaced with your link speed, in units
 508:LWIP/Target/ethernetif.c ****    * of bits per second.
 509:LWIP/Target/ethernetif.c ****    */
 510:LWIP/Target/ethernetif.c ****   // MIB2_INIT_NETIF(netif, snmp_ifType_ethernet_csmacd, LINK_SPEED_OF_YOUR_NETIF_IN_BPS);
 511:LWIP/Target/ethernetif.c **** 
 512:LWIP/Target/ethernetif.c ****   netif->name[0] = IFNAME0;
 513:LWIP/Target/ethernetif.c ****   netif->name[1] = IFNAME1;
 514:LWIP/Target/ethernetif.c ****   /* We directly use etharp_output() here to save a function call.
 515:LWIP/Target/ethernetif.c ****    * You can instead declare your own function an call etharp_output()
 516:LWIP/Target/ethernetif.c ****    * from it if you have to do some checks before sending (e.g. if link
 517:LWIP/Target/ethernetif.c ****    * is available...) */
 518:LWIP/Target/ethernetif.c **** 
 519:LWIP/Target/ethernetif.c **** #if LWIP_IPV4
 520:LWIP/Target/ethernetif.c **** #if LWIP_ARP || LWIP_ETHERNET
 521:LWIP/Target/ethernetif.c **** #if LWIP_ARP
 522:LWIP/Target/ethernetif.c ****   netif->output = etharp_output;
 523:LWIP/Target/ethernetif.c **** #else
 524:LWIP/Target/ethernetif.c ****   /* The user should write its own code in low_level_output_arp_off function */
 525:LWIP/Target/ethernetif.c ****   netif->output = low_level_output_arp_off;
 526:LWIP/Target/ethernetif.c **** #endif /* LWIP_ARP */
 527:LWIP/Target/ethernetif.c **** #endif /* LWIP_ARP || LWIP_ETHERNET */
 528:LWIP/Target/ethernetif.c **** #endif /* LWIP_IPV4 */
 529:LWIP/Target/ethernetif.c **** 
 530:LWIP/Target/ethernetif.c **** #if LWIP_IPV6
 531:LWIP/Target/ethernetif.c ****   netif->output_ip6 = ethip6_output;
 532:LWIP/Target/ethernetif.c **** #endif /* LWIP_IPV6 */
 533:LWIP/Target/ethernetif.c **** 
 534:LWIP/Target/ethernetif.c ****   netif->linkoutput = low_level_output;
 535:LWIP/Target/ethernetif.c **** 
 536:LWIP/Target/ethernetif.c ****   /* initialize the hardware */
 537:LWIP/Target/ethernetif.c ****   low_level_init(netif);
 538:LWIP/Target/ethernetif.c **** 
 539:LWIP/Target/ethernetif.c ****   return ERR_OK;
 540:LWIP/Target/ethernetif.c **** }
