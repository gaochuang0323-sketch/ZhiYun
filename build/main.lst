 233:Core/Src/main.c **** int __io_putchar(int ch)
 234:Core/Src/main.c **** {
 235:Core/Src/main.c ****   uint8_t data = (uint8_t)ch;
 236:Core/Src/main.c **** 
 237:Core/Src/main.c ****   /* Protect printf with mutex when RTOS is running */
 238:Core/Src/main.c ****   if ((osKernelGetState() == osKernelRunning) && (printfMutex != NULL))
 239:Core/Src/main.c ****   {
 240:Core/Src/main.c ****     (void)osMutexAcquire(printfMutex, osWaitForever);
 241:Core/Src/main.c ****     HAL_UART_Transmit(&huart1, &data, 1, HAL_MAX_DELAY);
 242:Core/Src/main.c ****     (void)osMutexRelease(printfMutex);
 243:Core/Src/main.c ****   }
 244:Core/Src/main.c ****   else
 245:Core/Src/main.c ****   {
 246:Core/Src/main.c ****     HAL_UART_Transmit(&huart1, &data, 1, HAL_MAX_DELAY);
 247:Core/Src/main.c ****   }
 248:Core/Src/main.c **** 
 249:Core/Src/main.c ****   return ch;
 250:Core/Src/main.c **** }
