 492:Middlewares/Third_Party/LwIP/src/core/inet_chksum.c ****                           u16_t chksum_len, const ip6_addr_t *src, const ip6_addr_t *dest)
 493:Middlewares/Third_Party/LwIP/src/core/inet_chksum.c **** {
