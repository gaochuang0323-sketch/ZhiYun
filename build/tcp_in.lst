1189:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****     /* (From Stevens TCP/IP Illustrated Vol II, p970.) Its only a
1190:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * duplicate ack if:
1191:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * 1) It doesn't ACK new data
1192:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * 2) length of received packet is zero (i.e. no payload)
1193:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * 3) the advertised window hasn't changed
1194:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * 4) There is outstanding unacknowledged data (retransmission timer running)
1195:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * 5) The ACK is == biggest ACK sequence number so far seen (snd_una)
1196:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      *
1197:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * If it passes all five, should process as a dupack:
1198:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * a) dupacks < 3: do nothing
1199:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * b) dupacks == 3: fast retransmit
1200:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * c) dupacks > 3: increase cwnd
1201:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      *
1202:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * If it only passes 1-3, should reset dupack counter (and add to
1203:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * stats, which we don't do in lwIP)
1204:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      *
1205:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      * If it only passes 1, should reset dupack counter
1206:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      *
1207:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****      */
1208:Middlewares/Third_Party/LwIP/src/core/tcp_in.c **** 
1209:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****     /* Clause 1 */
1210:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****     if (TCP_SEQ_LEQ(ackno, pcb->lastack)) {
1211:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****       /* Clause 2 */
1212:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****       if (tcplen == 0) {
1213:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****         /* Clause 3 */
1214:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****         if (pcb->snd_wl2 + pcb->snd_wnd == right_wnd_edge) {
1215:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****           /* Clause 4 */
1216:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****           if (pcb->rtime >= 0) {
1217:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****             /* Clause 5 */
1218:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****             if (pcb->lastack == ackno) {
1219:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****               if ((u8_t)(pcb->dupacks + 1) > pcb->dupacks) {
1220:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****                 ++pcb->dupacks;
1221:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****               }
1222:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****               if (pcb->dupacks > 3) {
1223:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****                 /* Inflate the congestion window */
1224:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****                 TCP_WND_INC(pcb->cwnd, pcb->mss);
1225:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****               }
1226:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****               if (pcb->dupacks >= 3) {
1227:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****                 /* Do fast retransmit (checked via TF_INFR, not via dupacks count) */
1228:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****                 tcp_rexmit_fast(pcb);
1229:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****               }
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccwQ5Ba6.s 			page 23


1230:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****             }
1231:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****           }
1232:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****         }
1233:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****       }
1234:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****     } else if (TCP_SEQ_BETWEEN(ackno, pcb->lastack + 1, pcb->snd_nxt)) {
1235:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****       /* We come here when the ACK acknowledges new data. */
1236:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****       tcpwnd_size_t acked;
1237:Middlewares/Third_Party/LwIP/src/core/tcp_in.c **** 
1238:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****       /* Reset the "IN Fast Retransmit" flag, since we are no longer
1239:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****          in fast retransmit. Also reset the congestion window to the
1240:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****          slow start threshold. */
1241:Middlewares/Third_Party/LwIP/src/core/tcp_in.c ****       if (pcb->flags & TF_INFR) {
