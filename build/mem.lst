 184:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 185:Middlewares/Third_Party/LwIP/src/core/mem.c **** /**
 186:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * Allocate a block of memory with a minimum of 'size' bytes.
 187:Middlewares/Third_Party/LwIP/src/core/mem.c ****  *
 188:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @param size is the minimum size of the requested block in bytes.
 189:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @return pointer to allocated memory or NULL if no free memory was found.
 190:Middlewares/Third_Party/LwIP/src/core/mem.c ****  *
 191:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * Note that the returned value must always be aligned (as defined by MEM_ALIGNMENT).
 192:Middlewares/Third_Party/LwIP/src/core/mem.c ****  */
 193:Middlewares/Third_Party/LwIP/src/core/mem.c **** void *
 194:Middlewares/Third_Party/LwIP/src/core/mem.c **** mem_malloc(mem_size_t size)
 195:Middlewares/Third_Party/LwIP/src/core/mem.c **** {
 196:Middlewares/Third_Party/LwIP/src/core/mem.c ****   void *ret = MEM_CUSTOM_MALLOC(size + MEM_LIBC_STATSHELPER_SIZE);
