  88:Middlewares/Third_Party/LwIP/src/core/mem.c **** /**
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRHlKMD.s 			page 3


  89:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * Check if a mep element was victim of an overflow or underflow
  90:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * (e.g. the restricted area after/before it has been altered)
  91:Middlewares/Third_Party/LwIP/src/core/mem.c ****  *
  92:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @param p the mem element to check
  93:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @param size allocated size of the element
  94:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @param descr1 description of the element source shown on error
  95:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @param descr2 description of the element source shown on error
  96:Middlewares/Third_Party/LwIP/src/core/mem.c ****  */
  97:Middlewares/Third_Party/LwIP/src/core/mem.c **** void
  98:Middlewares/Third_Party/LwIP/src/core/mem.c **** mem_overflow_check_raw(void *p, size_t size, const char *descr1, const char *descr2)
  99:Middlewares/Third_Party/LwIP/src/core/mem.c **** {
 100:Middlewares/Third_Party/LwIP/src/core/mem.c **** #if MEM_SANITY_REGION_AFTER_ALIGNED || MEM_SANITY_REGION_BEFORE_ALIGNED
 101:Middlewares/Third_Party/LwIP/src/core/mem.c ****   u16_t k;
 102:Middlewares/Third_Party/LwIP/src/core/mem.c ****   u8_t *m;
 103:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 104:Middlewares/Third_Party/LwIP/src/core/mem.c **** #if MEM_SANITY_REGION_AFTER_ALIGNED > 0
 105:Middlewares/Third_Party/LwIP/src/core/mem.c ****   m = (u8_t *)p + size;
 106:Middlewares/Third_Party/LwIP/src/core/mem.c ****   for (k = 0; k < MEM_SANITY_REGION_AFTER_ALIGNED; k++) {
 107:Middlewares/Third_Party/LwIP/src/core/mem.c ****     if (m[k] != 0xcd) {
 108:Middlewares/Third_Party/LwIP/src/core/mem.c ****       char errstr[128];
 109:Middlewares/Third_Party/LwIP/src/core/mem.c ****       snprintf(errstr, sizeof(errstr), "detected mem overflow in %s%s", descr1, descr2);
 110:Middlewares/Third_Party/LwIP/src/core/mem.c ****       LWIP_ASSERT(errstr, 0);
 111:Middlewares/Third_Party/LwIP/src/core/mem.c ****     }
 112:Middlewares/Third_Party/LwIP/src/core/mem.c ****   }
 113:Middlewares/Third_Party/LwIP/src/core/mem.c **** #endif /* MEM_SANITY_REGION_AFTER_ALIGNED > 0 */
 114:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 115:Middlewares/Third_Party/LwIP/src/core/mem.c **** #if MEM_SANITY_REGION_BEFORE_ALIGNED > 0
 116:Middlewares/Third_Party/LwIP/src/core/mem.c ****   m = (u8_t *)p - MEM_SANITY_REGION_BEFORE_ALIGNED;
 117:Middlewares/Third_Party/LwIP/src/core/mem.c ****   for (k = 0; k < MEM_SANITY_REGION_BEFORE_ALIGNED; k++) {
 118:Middlewares/Third_Party/LwIP/src/core/mem.c ****     if (m[k] != 0xcd) {
 119:Middlewares/Third_Party/LwIP/src/core/mem.c ****       char errstr[128];
 120:Middlewares/Third_Party/LwIP/src/core/mem.c ****       snprintf(errstr, sizeof(errstr), "detected mem underflow in %s%s", descr1, descr2);
 121:Middlewares/Third_Party/LwIP/src/core/mem.c ****       LWIP_ASSERT(errstr, 0);
 122:Middlewares/Third_Party/LwIP/src/core/mem.c ****     }
 123:Middlewares/Third_Party/LwIP/src/core/mem.c ****   }
 124:Middlewares/Third_Party/LwIP/src/core/mem.c **** #endif /* MEM_SANITY_REGION_BEFORE_ALIGNED > 0 */
 125:Middlewares/Third_Party/LwIP/src/core/mem.c **** #else
 126:Middlewares/Third_Party/LwIP/src/core/mem.c ****   LWIP_UNUSED_ARG(p);
 127:Middlewares/Third_Party/LwIP/src/core/mem.c ****   LWIP_UNUSED_ARG(desc);
 128:Middlewares/Third_Party/LwIP/src/core/mem.c ****   LWIP_UNUSED_ARG(descr);
 129:Middlewares/Third_Party/LwIP/src/core/mem.c **** #endif
 130:Middlewares/Third_Party/LwIP/src/core/mem.c **** }
 131:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 132:Middlewares/Third_Party/LwIP/src/core/mem.c **** /**
 133:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * Initialize the restricted area of a mem element.
