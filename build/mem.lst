 449:Middlewares/Third_Party/LwIP/src/core/mem.c **** /**
 450:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * "Plug holes" by combining adjacent empty struct mems.
 451:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * After this function is through, there should not exist
 452:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * one empty struct mem pointing to another empty struct mem.
 453:Middlewares/Third_Party/LwIP/src/core/mem.c ****  *
 454:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @param mem this points to a struct mem which just has been freed
 455:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * @internal this function is only called by mem_free() and mem_trim()
 456:Middlewares/Third_Party/LwIP/src/core/mem.c ****  *
 457:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * This assumes access to the heap is protected by the calling function
 458:Middlewares/Third_Party/LwIP/src/core/mem.c ****  * already.
 459:Middlewares/Third_Party/LwIP/src/core/mem.c ****  */
 460:Middlewares/Third_Party/LwIP/src/core/mem.c **** static void
 461:Middlewares/Third_Party/LwIP/src/core/mem.c **** plug_holes(struct mem *mem)
 462:Middlewares/Third_Party/LwIP/src/core/mem.c **** {
 463:Middlewares/Third_Party/LwIP/src/core/mem.c ****   struct mem *nmem;
 464:Middlewares/Third_Party/LwIP/src/core/mem.c ****   struct mem *pmem;
 465:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 466:Middlewares/Third_Party/LwIP/src/core/mem.c ****   LWIP_ASSERT("plug_holes: mem >= ram", (u8_t *)mem >= ram);
 467:Middlewares/Third_Party/LwIP/src/core/mem.c ****   LWIP_ASSERT("plug_holes: mem < ram_end", (u8_t *)mem < (u8_t *)ram_end);
 468:Middlewares/Third_Party/LwIP/src/core/mem.c ****   LWIP_ASSERT("plug_holes: mem->used == 0", mem->used == 0);
 469:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 470:Middlewares/Third_Party/LwIP/src/core/mem.c ****   /* plug hole forward */
 471:Middlewares/Third_Party/LwIP/src/core/mem.c ****   LWIP_ASSERT("plug_holes: mem->next <= MEM_SIZE_ALIGNED", mem->next <= MEM_SIZE_ALIGNED);
 472:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 473:Middlewares/Third_Party/LwIP/src/core/mem.c ****   nmem = ptr_to_mem(mem->next);
 474:Middlewares/Third_Party/LwIP/src/core/mem.c ****   if (mem != nmem && nmem->used == 0 && (u8_t *)nmem != (u8_t *)ram_end) {
 475:Middlewares/Third_Party/LwIP/src/core/mem.c ****     /* if mem->next is unused and not end of ram, combine mem and mem->next */
 476:Middlewares/Third_Party/LwIP/src/core/mem.c ****     if (lfree == nmem) {
 477:Middlewares/Third_Party/LwIP/src/core/mem.c ****       lfree = mem;
 478:Middlewares/Third_Party/LwIP/src/core/mem.c ****     }
 479:Middlewares/Third_Party/LwIP/src/core/mem.c ****     mem->next = nmem->next;
 480:Middlewares/Third_Party/LwIP/src/core/mem.c ****     if (nmem->next != MEM_SIZE_ALIGNED) {
 481:Middlewares/Third_Party/LwIP/src/core/mem.c ****       ptr_to_mem(nmem->next)->prev = mem_to_ptr(mem);
 482:Middlewares/Third_Party/LwIP/src/core/mem.c ****     }
 483:Middlewares/Third_Party/LwIP/src/core/mem.c ****   }
 484:Middlewares/Third_Party/LwIP/src/core/mem.c **** 
 485:Middlewares/Third_Party/LwIP/src/core/mem.c ****   /* plug hole backward */
 486:Middlewares/Third_Party/LwIP/src/core/mem.c ****   pmem = ptr_to_mem(mem->prev);
 487:Middlewares/Third_Party/LwIP/src/core/mem.c ****   if (pmem != mem && pmem->used == 0) {
 488:Middlewares/Third_Party/LwIP/src/core/mem.c ****     /* if mem->prev is unused, combine mem and mem->prev */
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRHlKMD.s 			page 11


