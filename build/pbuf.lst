 630:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /**
 631:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Adjusts the payload pointer to hide or reveal headers in the payload.
 632:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 633:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Adjusts the ->payload pointer so that space for a header
 634:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * (dis)appears in the pbuf payload.
 635:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 636:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * The ->payload, ->tot_len and ->len fields are adjusted.
 637:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 638:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param p pbuf to change the header size.
 639:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param header_size_increment Number of bytes to increment header size which
 640:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * increases the size of the pbuf. New space is on the front.
 641:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * (Using a negative value decreases the header size.)
 642:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * If header_size_increment is 0, this function does nothing and returns successful.
 643:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 644:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * PBUF_ROM and PBUF_REF type buffers cannot have their sizes increased, so
 645:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * the call will fail. A check is made that the increase in header size does
 646:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * not move the payload pointer in front of the start of the buffer.
 647:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @return non-zero on failure, zero on success.
 648:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 649:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 650:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** u8_t
 651:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_header(struct pbuf *p, s16_t header_size_increment)
 652:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 653:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   return pbuf_header_impl(p, header_size_increment, 0);
 654:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
 655:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 656:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /**
 657:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Same as pbuf_header but does not check if 'header_size > 0' is allowed.
 658:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * This is used internally only, to allow PBUF_REF for RX.
 659:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 660:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** u8_t
 661:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_header_force(struct pbuf *p, s16_t header_size_increment)
 662:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 663:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   return pbuf_header_impl(p, header_size_increment, 1);
 664:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
 665:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 666:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /** Similar to pbuf_header(-size) but de-refs header pbufs for (size >= p->len)
 667:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRxobqB.s 			page 14


 668:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param q pbufs to operate on
 669:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param size The number of bytes to remove from the beginning of the pbuf list.
 670:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             While size >= p->len, pbufs are freed.
 671:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *        ATTENTION: this is the opposite direction as @ref pbuf_header, but
 672:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *                   takes an u16_t not s16_t!
 673:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @return the new head pbuf
 674:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 675:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** struct pbuf *
 676:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_free_header(struct pbuf *q, u16_t size)
 677:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 678:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   struct pbuf *p = q;
 679:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   u16_t free_left = size;
 680:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   while (free_left && p) {
 681:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     if (free_left >= p->len) {
 682:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       struct pbuf *f = p;
 683:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       free_left = (u16_t)(free_left - p->len);
 684:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       p = p->next;
 685:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       f->next = NULL;
 686:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       pbuf_free(f);
 687:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     } else {
 688:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       pbuf_remove_header(p, free_left);
 689:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       free_left = 0;
 690:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     }
 691:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
 692:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   return p;
 693:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
 694:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 695:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /**
 696:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @ingroup pbuf
 697:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Dereference a pbuf chain or queue and deallocate any no-longer-used
 698:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * pbufs at the head of this chain or queue.
 699:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 700:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Decrements the pbuf reference count. If it reaches zero, the pbuf is
 701:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * deallocated.
 702:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 703:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * For a pbuf chain, this is repeated for each pbuf in the chain,
 704:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * up to the first pbuf which has a non-zero reference count after
 705:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * decrementing. So, when all reference counts are one, the whole
 706:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * chain is free'd.
 707:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 708:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param p The pbuf (chain) to be dereferenced.
 709:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 710:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @return the number of pbufs that were de-allocated
 711:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * from the head of the chain.
 712:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 713:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @note the reference counter of a pbuf equals the number of pointers
 714:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * that refer to the pbuf (or into the pbuf).
 715:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 716:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @internal examples:
 717:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 718:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Assuming existing chains a->b->c with the following reference
 719:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * counts, calling pbuf_free(a) results in:
 720:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 721:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * 1->2->3 becomes ...1->3
 722:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * 3->3->3 becomes 2->3->3
 723:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * 1->1->2 becomes ......1
 724:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * 2->1->1 becomes 1->1->1
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRxobqB.s 			page 15


 725:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * 1->1->1 becomes .......
 726:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 727:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 728:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** u8_t
 729:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_free(struct pbuf *p)
 730:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 731:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   u8_t alloc_src;
 732:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   struct pbuf *q;
