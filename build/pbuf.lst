1318:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_coalesce(struct pbuf *p, pbuf_layer layer)
1319:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
1320:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   struct pbuf *q;
1321:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   if (p->next == NULL) {
1322:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     return p;
1323:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
1324:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   q = pbuf_clone(layer, PBUF_RAM, p);
1325:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   if (q == NULL) {
1326:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     /* @todo: what do we do now? */
1327:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     return p;
1328:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
1329:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   pbuf_free(p);
1330:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   return q;
1331:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
