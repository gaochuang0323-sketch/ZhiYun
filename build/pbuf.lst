 894:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * The ->tot_len fields of all pbufs of the head chain are adjusted.
 895:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * The ->next field of the last pbuf of the head chain is adjusted.
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRxobqB.s 			page 18


 896:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * The ->ref field of the first pbuf of the tail chain is adjusted.
 897:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 898:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 899:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** void
 900:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_chain(struct pbuf *h, struct pbuf *t)
 901:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 902:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   pbuf_cat(h, t);
 903:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   /* t is now referenced by h */
 904:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   pbuf_ref(t);
 905:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_DEBUGF(PBUF_DEBUG | LWIP_DBG_TRACE, ("pbuf_chain: %p references %p\n", (void *)h, (void *)t)
 906:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
