 193:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /**
 194:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @ingroup pbuf
 195:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Allocates a pbuf of the given type (possibly a chain for PBUF_POOL type).
 196:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 197:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * The actual memory allocated for the pbuf is determined by the
 198:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * layer at which the pbuf is allocated and the requested size
 199:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * (from the size parameter).
 200:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 201:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param layer header size
 202:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param length size of the pbuf's payload
 203:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param type this parameter decides how and where the pbuf
 204:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * should be allocated as follows:
 205:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 206:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * - PBUF_RAM: buffer memory for pbuf is allocated as one large
 207:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             chunk. This includes protocol headers as well.
 208:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * - PBUF_ROM: no buffer memory is allocated for the pbuf, even for
 209:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             protocol headers. Additional headers must be prepended
 210:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             by allocating another pbuf and chain in to the front of
 211:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             the ROM pbuf. It is assumed that the memory used is really
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRxobqB.s 			page 6


 212:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             similar to ROM in that it is immutable and will not be
 213:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             changed. Memory which is dynamic should generally not
 214:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             be attached to PBUF_ROM pbufs. Use PBUF_REF instead.
 215:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * - PBUF_REF: no buffer memory is allocated for the pbuf, even for
 216:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             protocol headers. It is assumed that the pbuf is only
 217:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             being used in a single thread. If the pbuf gets queued,
 218:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             then pbuf_take should be called to copy the buffer.
 219:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * - PBUF_POOL: the pbuf is allocated as a pbuf chain, with pbufs from
 220:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *              the pbuf pool that is allocated during pbuf_init().
 221:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 222:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @return the allocated pbuf. If multiple pbufs where allocated, this
 223:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * is the first pbuf of a pbuf chain.
 224:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 225:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** struct pbuf *
 226:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_alloc(pbuf_layer layer, u16_t length, pbuf_type type)
 227:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 228:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   struct pbuf *p;
 229:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   u16_t offset = (u16_t)layer;
 230:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_DEBUGF(PBUF_DEBUG | LWIP_DBG_TRACE, ("pbuf_alloc(length=%"U16_F")\n", length));
 231:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 232:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   switch (type) {
 233:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     case PBUF_REF: /* fall through */
 234:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     case PBUF_ROM:
 235:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       p = pbuf_alloc_reference(NULL, length, type);
 236:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       break;
 237:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     case PBUF_POOL: {
 238:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       struct pbuf *q, *last;
 239:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       u16_t rem_len; /* remaining length */
 240:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       p = NULL;
 241:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       last = NULL;
 242:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       rem_len = length;
 243:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       do {
 244:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         u16_t qlen;
 245:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         q = (struct pbuf *)memp_malloc(MEMP_PBUF_POOL);
 246:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         if (q == NULL) {
 247:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           PBUF_POOL_IS_EMPTY();
 248:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           /* free chain so far allocated */
 249:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           if (p) {
 250:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****             pbuf_free(p);
 251:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           }
 252:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           /* bail out unsuccessfully */
 253:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           return NULL;
 254:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         }
 255:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         qlen = LWIP_MIN(rem_len, (u16_t)(PBUF_POOL_BUFSIZE_ALIGNED - LWIP_MEM_ALIGN_SIZE(offset)));
 256:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         pbuf_init_alloced_pbuf(q, LWIP_MEM_ALIGN((void *)((u8_t *)q + SIZEOF_STRUCT_PBUF + offset))
 257:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                                rem_len, qlen, type, 0);
 258:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         LWIP_ASSERT("pbuf_alloc: pbuf q->payload properly aligned",
 259:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                     ((mem_ptr_t)q->payload % MEM_ALIGNMENT) == 0);
 260:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         LWIP_ASSERT("PBUF_POOL_BUFSIZE must be bigger than MEM_ALIGNMENT",
 261:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                     (PBUF_POOL_BUFSIZE_ALIGNED - LWIP_MEM_ALIGN_SIZE(offset)) > 0 );
 262:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         if (p == NULL) {
 263:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           /* allocated head of pbuf chain (into p) */
 264:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           p = q;
 265:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         } else {
 266:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           /* make previous pbuf point to this pbuf */
 267:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           last->next = q;
 268:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         }
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRxobqB.s 			page 7


 269:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         last = q;
 270:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         rem_len = (u16_t)(rem_len - qlen);
 271:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         offset = 0;
 272:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       } while (rem_len > 0);
 273:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       break;
 274:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     }
 275:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     case PBUF_RAM: {
 276:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       mem_size_t payload_len = (mem_size_t)(LWIP_MEM_ALIGN_SIZE(offset) + LWIP_MEM_ALIGN_SIZE(lengt
 277:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       mem_size_t alloc_len = (mem_size_t)(LWIP_MEM_ALIGN_SIZE(SIZEOF_STRUCT_PBUF) + payload_len);
 278:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 279:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       /* bug #50040: Check for integer overflow when calculating alloc_len */
 280:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       if ((payload_len < LWIP_MEM_ALIGN_SIZE(length)) ||
 281:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****           (alloc_len < LWIP_MEM_ALIGN_SIZE(length))) {
 282:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         return NULL;
 283:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       }
 284:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 285:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       /* If pbuf is to be allocated in RAM, allocate memory for it. */
 286:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       p = (struct pbuf *)mem_malloc(alloc_len);
 287:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       if (p == NULL) {
 288:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****         return NULL;
 289:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       }
 290:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       pbuf_init_alloced_pbuf(p, LWIP_MEM_ALIGN((void *)((u8_t *)p + SIZEOF_STRUCT_PBUF + offset)),
 291:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                              length, length, type, 0);
 292:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       LWIP_ASSERT("pbuf_alloc: pbuf->payload properly aligned",
 293:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                   ((mem_ptr_t)p->payload % MEM_ALIGNMENT) == 0);
 294:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       break;
 295:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     }
 296:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     default:
 297:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       LWIP_ASSERT("pbuf_alloc: erroneous type", 0);
 298:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****       return NULL;
 299:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
 300:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_DEBUGF(PBUF_DEBUG | LWIP_DBG_TRACE, ("pbuf_alloc(length=%"U16_F") == %p\n", length, (void *)
 301:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   return p;
 302:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
