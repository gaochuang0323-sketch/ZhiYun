 304:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /**
 305:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @ingroup pbuf
 306:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Allocates a pbuf for referenced data.
 307:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Referenced data can be volatile (PBUF_REF) or long-lived (PBUF_ROM).
 308:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 309:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * The actual memory allocated for the pbuf is determined by the
 310:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * layer at which the pbuf is allocated and the requested size
 311:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * (from the size parameter).
 312:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 313:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param payload referenced payload
 314:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param length size of the pbuf's payload
 315:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param type this parameter decides how and where the pbuf
 316:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * should be allocated as follows:
 317:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 318:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * - PBUF_ROM: It is assumed that the memory used is really
 319:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             similar to ROM in that it is immutable and will not be
 320:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             changed. Memory which is dynamic should generally not
 321:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             be attached to PBUF_ROM pbufs. Use PBUF_REF instead.
 322:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * - PBUF_REF: It is assumed that the pbuf is only
 323:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             being used in a single thread. If the pbuf gets queued,
 324:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *             then pbuf_take should be called to copy the buffer.
 325:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRxobqB.s 			page 8


 326:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @return the allocated pbuf.
 327:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 328:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** struct pbuf *
 329:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_alloc_reference(void *payload, u16_t length, pbuf_type type)
 330:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 331:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   struct pbuf *p;
 332:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_ASSERT("invalid pbuf_type", (type == PBUF_REF) || (type == PBUF_ROM));
 333:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   /* only allocate memory for the pbuf structure */
 334:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   p = (struct pbuf *)memp_malloc(MEMP_PBUF);
 335:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   if (p == NULL) {
 336:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     LWIP_DEBUGF(PBUF_DEBUG | LWIP_DBG_LEVEL_SERIOUS,
 337:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                 ("pbuf_alloc_reference: Could not allocate MEMP_PBUF for PBUF_%s.\n",
 338:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                  (type == PBUF_ROM) ? "ROM" : "REF"));
 339:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     return NULL;
 340:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
 341:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   pbuf_init_alloced_pbuf(p, payload, length, length, type, 0);
 342:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   return p;
 343:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
