 856:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** void
 857:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_cat(struct pbuf *h, struct pbuf *t)
 858:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 859:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   struct pbuf *p;
 860:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 861:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_ERROR("(h != NULL) && (t != NULL) (programmer violates API)",
 862:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****              ((h != NULL) && (t != NULL)), return;);
 863:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_ASSERT("Creating an infinite loop", h != t);
 864:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 865:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   /* proceed to last pbuf of chain */
 866:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   for (p = h; p->next != NULL; p = p->next) {
 867:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     /* add total length of second chain to all totals of first chain */
 868:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     p->tot_len = (u16_t)(p->tot_len + t->tot_len);
 869:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
 870:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   /* { p is last pbuf of first h chain, p->next == NULL } */
 871:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_ASSERT("p->tot_len == p->len (of last pbuf in chain)", p->tot_len == p->len);
 872:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_ASSERT("p->next == NULL", p->next == NULL);
 873:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   /* add total length of second chain to last pbuf total of first chain */
 874:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   p->tot_len = (u16_t)(p->tot_len + t->tot_len);
 875:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   /* chain last pbuf of head (p) with first of tail (t) */
 876:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   p->next = t;
 877:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   /* p->next now references t, but the caller will drop its reference to t,
 878:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****    * so netto there is no change to the reference count of t.
 879:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****    */
 880:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
