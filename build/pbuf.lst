 346:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** #if LWIP_SUPPORT_CUSTOM_PBUF
 347:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /**
 348:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @ingroup pbuf
 349:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Initialize a custom pbuf (already allocated).
 350:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Example of custom pbuf usage: @ref zerocopyrx
 351:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 352:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param l header size
 353:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param length size of the pbuf's payload
 354:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param type type of the pbuf (only used to treat the pbuf accordingly, as
 355:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *        this function allocates no memory)
 356:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param p pointer to the custom pbuf to initialize (already allocated)
 357:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param payload_mem pointer to the buffer that is used for payload and headers,
 358:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *        must be at least big enough to hold 'length' plus the header size,
 359:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *        may be NULL if set later.
 360:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *        ATTENTION: The caller is responsible for correct alignment of this buffer!!
 361:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param payload_mem_len the size of the 'payload_mem' buffer, must be at least
 362:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *        big enough to hold 'length' plus the header size
 363:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 364:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** struct pbuf *
 365:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** pbuf_alloced_custom(pbuf_layer l, u16_t length, pbuf_type type, struct pbuf_custom *p,
 366:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****                     void *payload_mem, u16_t payload_mem_len)
 367:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** {
 368:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   u16_t offset = (u16_t)l;
 369:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   void *payload;
 370:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   LWIP_DEBUGF(PBUF_DEBUG | LWIP_DBG_TRACE, ("pbuf_alloced_custom(length=%"U16_F")\n", length));
 371:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 372:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   if (LWIP_MEM_ALIGN_SIZE(offset) + length > payload_mem_len) {
 373:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     LWIP_DEBUGF(PBUF_DEBUG | LWIP_DBG_LEVEL_WARNING, ("pbuf_alloced_custom(length=%"U16_F") buffer 
 374:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     return NULL;
 375:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
 376:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 377:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   if (payload_mem != NULL) {
 378:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     payload = (u8_t *)payload_mem + LWIP_MEM_ALIGN_SIZE(offset);
 379:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   } else {
 380:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****     payload = NULL;
 381:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   }
 382:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   pbuf_init_alloced_pbuf(&p->pbuf, payload, length, length, type, PBUF_FLAG_IS_CUSTOM);
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccRxobqB.s 			page 9


 383:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****   return &p->pbuf;
 384:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** }
 385:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** #endif /* LWIP_SUPPORT_CUSTOM_PBUF */
 386:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** 
 387:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** /**
 388:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @ingroup pbuf
 389:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Shrink a pbuf chain to a desired length.
 390:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 391:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param p pbuf to shrink.
 392:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @param new_len desired new length of pbuf chain
 393:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 394:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * Depending on the desired length, the first few pbufs in a chain might
 395:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * be skipped and left unchanged. The new last pbuf in the chain will be
 396:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * resized, and any remaining pbufs will be freed.
 397:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 398:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @note If the pbuf is ROM/REF, only the ->tot_len and ->len fields are adjusted.
 399:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @note May not be called on a packet queue.
 400:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  *
 401:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  * @note Despite its name, pbuf_realloc cannot grow the size of a pbuf (chain).
 402:Middlewares/Third_Party/LwIP/src/core/pbuf.c ****  */
 403:Middlewares/Third_Party/LwIP/src/core/pbuf.c **** void
