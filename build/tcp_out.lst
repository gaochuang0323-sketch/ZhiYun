 456:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****   /*
 457:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * TCP segmentation is done in three phases with increasing complexity:
 458:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    *
 459:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * 1. Copy data directly into an oversized pbuf.
 460:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * 2. Chain a new pbuf to the end of pcb->unsent.
 461:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * 3. Create new segments.
 462:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    *
 463:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * We may run out of memory at any point. In that case we must
 464:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * return ERR_MEM and not change anything in pcb. Therefore, all
 465:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * changes are recorded in local variables and committed at the end
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccxbZYFZ.s 			page 14


 466:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * of the function. Some pcb fields are maintained in local copies:
 467:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    *
 468:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * queuelen = pcb->snd_queuelen
 469:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * oversize = pcb->unsent_oversize
 470:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    *
 471:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * These variables are set consistently by the phases:
 472:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    *
 473:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * seg points to the last segment tampered with.
 474:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    *
 475:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    * pos records progress as data is segmented.
 476:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****    */
 477:Middlewares/Third_Party/LwIP/src/core/tcp_out.c **** 
 478:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****   /* Find the tail of the unsent queue. */
 479:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****   if (pcb->unsent != NULL) {
 480:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****     u16_t space;
 481:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****     u16_t unsent_optlen;
 482:Middlewares/Third_Party/LwIP/src/core/tcp_out.c **** 
 483:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****     /* @todo: this could be sped up by keeping last_unsent in the pcb */
 484:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****     for (last_unsent = pcb->unsent; last_unsent->next != NULL;
 485:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****          last_unsent = last_unsent->next);
 486:Middlewares/Third_Party/LwIP/src/core/tcp_out.c **** 
 487:Middlewares/Third_Party/LwIP/src/core/tcp_out.c ****     /* Usable space at the end of the last unsent segment */
