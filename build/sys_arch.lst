  76:Middlewares/Third_Party/LwIP/system/OS/sys_arch.c **** /* Flag the core lock held. A counter for recursive locks. */
  77:Middlewares/Third_Party/LwIP/system/OS/sys_arch.c **** static u8_t lwip_core_lock_count;
  78:Middlewares/Third_Party/LwIP/system/OS/sys_arch.c **** /* Mark the current core lock holder. */
