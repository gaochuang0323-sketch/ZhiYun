2646:Middlewares/Third_Party/LwIP/src/api/sockets.c ****       }
2647:Middlewares/Third_Party/LwIP/src/api/sockets.c **** #endif /* LWIP_SOCKET_POLL */
2648:Middlewares/Third_Party/LwIP/src/api/sockets.c **** #if LWIP_SOCKET_SELECT && LWIP_SOCKET_POLL
2649:Middlewares/Third_Party/LwIP/src/api/sockets.c ****       else
2650:Middlewares/Third_Party/LwIP/src/api/sockets.c **** #endif /* LWIP_SOCKET_SELECT && LWIP_SOCKET_POLL */
2651:Middlewares/Third_Party/LwIP/src/api/sockets.c **** #if LWIP_SOCKET_SELECT
2652:Middlewares/Third_Party/LwIP/src/api/sockets.c ****       {
2653:Middlewares/Third_Party/LwIP/src/api/sockets.c ****         /* Test this select call for our socket */
2654:Middlewares/Third_Party/LwIP/src/api/sockets.c ****         if (has_recvevent) {
