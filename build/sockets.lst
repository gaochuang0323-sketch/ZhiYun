2732:Middlewares/Third_Party/LwIP/src/api/sockets.c ****     shut_rx = 1;
2733:Middlewares/Third_Party/LwIP/src/api/sockets.c ****     shut_tx = 1;
2734:Middlewares/Third_Party/LwIP/src/api/sockets.c ****   } else {
