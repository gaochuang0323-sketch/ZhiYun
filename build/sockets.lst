2628:Middlewares/Third_Party/LwIP/src/api/sockets.c ****   SYS_ARCH_DECL_PROTECT(lev);
2629:Middlewares/Third_Party/LwIP/src/api/sockets.c **** #endif /* !LWIP_TCPIP_CORE_LOCKING */
2630:Middlewares/Third_Party/LwIP/src/api/sockets.c **** 
2631:Middlewares/Third_Party/LwIP/src/api/sockets.c ****   LWIP_ASSERT_CORE_LOCKED();
