2633:Middlewares/Third_Party/LwIP/src/api/sockets.c **** #if !LWIP_TCPIP_CORE_LOCKING
2634:Middlewares/Third_Party/LwIP/src/api/sockets.c ****   SYS_ARCH_PROTECT(lev);
2635:Middlewares/Third_Party/LwIP/src/api/sockets.c **** again:
2636:Middlewares/Third_Party/LwIP/src/api/sockets.c ****   /* remember the state of select_cb_list to detect changes */
2637:Middlewares/Third_Party/LwIP/src/api/sockets.c ****   last_select_cb_ctr = select_cb_ctr;
2638:Middlewares/Third_Party/LwIP/src/api/sockets.c **** #endif /* !LWIP_TCPIP_CORE_LOCKING */
2639:Middlewares/Third_Party/LwIP/src/api/sockets.c ****   for (scb = select_cb_list; scb != NULL; scb = scb->next) {
