 191:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c **** /**
 192:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****  * Clears expired entries in the ARP table.
 193:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****  *
 194:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****  * This function should be called every ARP_TMR_INTERVAL milliseconds (1 second),
 195:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****  * in order to expire entries in the ARP table.
 196:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****  */
 197:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c **** void
 198:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c **** etharp_tmr(void)
 199:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c **** {
 200:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****   int i;
 201:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c **** 
 202:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****   LWIP_DEBUGF(ETHARP_DEBUG, ("etharp_timer\n"));
 203:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****   /* remove expired entries from the ARP table */
 204:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****   for (i = 0; i < ARP_TABLE_SIZE; ++i) {
 205:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****     u8_t state = arp_table[i].state;
 206:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****     if (state != ETHARP_STATE_EMPTY
 207:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c **** #if ETHARP_SUPPORT_STATIC_ENTRIES
 208:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         && (state != ETHARP_STATE_STATIC)
 209:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c **** #endif /* ETHARP_SUPPORT_STATIC_ENTRIES */
 210:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****        ) {
 211:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****       arp_table[i].ctime++;
 212:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****       if ((arp_table[i].ctime >= ARP_MAXAGE) ||
 213:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****           ((arp_table[i].state == ETHARP_STATE_PENDING)  &&
 214:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****            (arp_table[i].ctime >= ARP_MAXPENDING))) {
 215:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         /* pending or stable entry has become old! */
 216:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         LWIP_DEBUGF(ETHARP_DEBUG, ("etharp_timer: expired %s entry %d.\n",
 217:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****                                    arp_table[i].state >= ETHARP_STATE_STABLE ? "stable" : "pending"
 218:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         /* clean up entries that have just been expired */
 219:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         etharp_free_entry(i);
 220:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****       } else if (arp_table[i].state == ETHARP_STATE_STABLE_REREQUESTING_1) {
 221:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         /* Don't send more than one request every 2 seconds. */
 222:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         arp_table[i].state = ETHARP_STATE_STABLE_REREQUESTING_2;
ARM GAS  C:\Users\hh\AppData\Local\Temp\ccKlMI3R.s 			page 7


 223:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****       } else if (arp_table[i].state == ETHARP_STATE_STABLE_REREQUESTING_2) {
 224:Middlewares/Third_Party/LwIP/src/core/ipv4/etharp.c ****         /* Reset state to stable, so that the next transmitted packet will
