2547:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     {
2548:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         BaseType_t xReturn;
2549:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         Queue_t * const pxQueue = xQueue;
2550:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** 
2551:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         /* If the queue is already full we may have to block.  A critical section
2552:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****          * is required to prevent an interrupt removing something from the queue
2553:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****          * between the check to see if the queue is full and blocking on the queue. */
2554:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         portDISABLE_INTERRUPTS();
2555:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         {
2556:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             if( prvIsQueueFull( pxQueue ) != pdFALSE )
2557:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             {
2558:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****                 /* The queue is full - do we want to block or just leave without
2559:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****                  * posting? */
2560:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****                 if( xTicksToWait > ( TickType_t ) 0 )
2561:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****                 {
