 261:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         }                                                  \
 262:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     }                                                      \
 263:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     taskEXIT_CRITICAL()
 264:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** 
 265:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** /*
 266:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  * Macro to increment cTxLock member of the queue data structure. It is
 267:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  * capped at the number of tasks in the system as we cannot unblock more
 268:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  * tasks than the number of tasks in the system.
 269:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  */
 270:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** #define prvIncrementQueueTxLock( pxQueue, cTxLock )                           \
 271:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     do {                                                                      \
 272:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         const UBaseType_t uxNumberOfTasks = uxTaskGetNumberOfTasks();         \
 273:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         if( ( UBaseType_t ) ( cTxLock ) < uxNumberOfTasks )                   \
 274:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         {                                                                     \
 275:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             configASSERT( ( cTxLock ) != queueINT8_MAX );                     \
 276:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             ( pxQueue )->cTxLock = ( int8_t ) ( ( cTxLock ) + ( int8_t ) 1 ); \
 277:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         }                                                                     \
 278:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     } while( 0 )
 279:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** 
 280:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** /*
 281:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  * Macro to increment cRxLock member of the queue data structure. It is
 282:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  * capped at the number of tasks in the system as we cannot unblock more
