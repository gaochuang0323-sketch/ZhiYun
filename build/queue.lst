 286:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     do {                                                                      \
 287:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         const UBaseType_t uxNumberOfTasks = uxTaskGetNumberOfTasks();         \
 288:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         if( ( UBaseType_t ) ( cRxLock ) < uxNumberOfTasks )                   \
 289:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         {                                                                     \
 290:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             configASSERT( ( cRxLock ) != queueINT8_MAX );                     \
 291:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             ( pxQueue )->cRxLock = ( int8_t ) ( ( cRxLock ) + ( int8_t ) 1 ); \
 292:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         }                                                                     \
 293:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     } while( 0 )
