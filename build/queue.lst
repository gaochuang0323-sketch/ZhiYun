 247:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** /*
 248:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  * Macro to mark a queue as locked.  Locking a queue prevents an ISR from
 249:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  * accessing the queue event lists.
 250:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****  */
 251:Middlewares/Third_Party/FreeRTOS/Source/queue.c **** #define prvLockQueue( pxQueue )                            \
 252:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     taskENTER_CRITICAL();                                  \
 253:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     {                                                      \
 254:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         if( ( pxQueue )->cRxLock == queueUNLOCKED )        \
 255:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         {                                                  \
 256:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             ( pxQueue )->cRxLock = queueLOCKED_UNMODIFIED; \
 257:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         }                                                  \
 258:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         if( ( pxQueue )->cTxLock == queueUNLOCKED )        \
 259:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         {                                                  \
