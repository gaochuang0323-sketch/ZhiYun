 792:Middlewares/Third_Party/LwIP/src/core/tcp.c **** /**
 793:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * @ingroup tcp_raw
 794:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * Set the state of the connection to be LISTEN, which means that it
 795:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * is able to accept incoming connections. The protocol control block
 796:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * is reallocated in order to consume less memory. Setting the
 797:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * connection to LISTEN is an irreversible process.
 798:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * When an incoming connection is accepted, the function specified with
 799:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * the tcp_accept() function will be called. The pcb has to be bound
 800:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * to a local port with the tcp_bind() function.
 801:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  *
 802:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * The tcp_listen() function returns a new connection identifier, and
 803:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * the one passed as an argument to the function will be
 804:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * deallocated. The reason for this behavior is that less memory is
 805:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * needed for a connection that is listening, so tcp_listen() will
 806:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * reclaim the memory needed for the original connection and allocate a
 807:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * new smaller memory block for the listening connection.
 808:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  *
 809:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * tcp_listen() may return NULL if no memory was available for the
 810:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * listening connection. If so, the memory associated with the pcb
 811:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * passed as an argument to tcp_listen() will not be deallocated.
 812:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  *
 813:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * The backlog limits the number of outstanding connections
 814:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * in the listen queue to the value specified by the backlog argument.
 815:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * To use it, your need to set TCP_LISTEN_BACKLOG=1 in your lwipopts.h.
 816:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  *
 817:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * @param pcb the original tcp_pcb
 818:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * @param backlog the incoming connections queue limit
 819:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * @return tcp_pcb used for listening, consumes less memory.
 820:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  *
 821:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  * @note The original tcp_pcb is freed. This function therefore has to be
 822:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  *       called like this:
 823:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  *             tpcb = tcp_listen_with_backlog(tpcb, backlog);
 824:Middlewares/Third_Party/LwIP/src/core/tcp.c ****  */
 825:Middlewares/Third_Party/LwIP/src/core/tcp.c **** struct tcp_pcb *
 826:Middlewares/Third_Party/LwIP/src/core/tcp.c **** tcp_listen_with_backlog(struct tcp_pcb *pcb, u8_t backlog)
 827:Middlewares/Third_Party/LwIP/src/core/tcp.c **** {
 828:Middlewares/Third_Party/LwIP/src/core/tcp.c ****   LWIP_ASSERT_CORE_LOCKED();
 829:Middlewares/Third_Party/LwIP/src/core/tcp.c ****   return tcp_listen_with_backlog_and_err(pcb, backlog, NULL);
 830:Middlewares/Third_Party/LwIP/src/core/tcp.c **** }
