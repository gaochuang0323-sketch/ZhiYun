 649:App/Src/fault_command.c ****     {
 650:App/Src/fault_command.c ****       return HAL_ERROR;
 651:App/Src/fault_command.c ****     }
 652:App/Src/fault_command.c **** 
 653:App/Src/fault_command.c ****     value = strtoul(cursor, &endPtr, 16);
 654:App/Src/fault_command.c ****     if ((endPtr == cursor) || (value > 0xFFUL))
 655:App/Src/fault_command.c ****     {
 656:App/Src/fault_command.c ****       return HAL_ERROR;
 657:App/Src/fault_command.c ****     }
 658:App/Src/fault_command.c **** 
 659:App/Src/fault_command.c ****     data[index] = (uint8_t)value;
 660:App/Src/fault_command.c ****     cursor = endPtr;
 661:App/Src/fault_command.c ****   }
 662:App/Src/fault_command.c **** 
 663:App/Src/fault_command.c ****   return BspCan_SendClassic((uint32_t)id, 0U, data, (uint8_t)length);
 664:App/Src/fault_command.c **** }
