 623:App/Src/fault_command.c **** static HAL_StatusTypeDef FaultCommand_ParseCanSendText(const char *line)
 624:App/Src/fault_command.c **** {
 625:App/Src/fault_command.c ****   unsigned long id;
 626:App/Src/fault_command.c ****   unsigned int length;
 627:App/Src/fault_command.c ****   int consumed = 0;
 628:App/Src/fault_command.c ****   const char *cursor;
 629:App/Src/fault_command.c ****   uint8_t data[BSP_CAN_MAX_DATA_LEN] = {0};
 630:App/Src/fault_command.c **** 
