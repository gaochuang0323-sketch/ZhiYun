 559:App/Src/fault_command.c **** {
 560:App/Src/fault_command.c ****   unsigned long id;
 561:App/Src/fault_command.c ****   unsigned int length;
 562:App/Src/fault_command.c ****   int consumed = 0;
 563:App/Src/fault_command.c ****   const char *cursor;
 564:App/Src/fault_command.c ****   uint8_t data[BSP_CAN_MAX_DATA_LEN] = {0};
 565:App/Src/fault_command.c **** 
 566:App/Src/fault_command.c ****   if (sscanf(line, "can send %lx %u %n", &id, &length, &consumed) < 2)
 567:App/Src/fault_command.c ****   {
 568:App/Src/fault_command.c ****     return HAL_ERROR;
 569:App/Src/fault_command.c ****   }
 570:App/Src/fault_command.c **** 
