 580:App/Src/fault_command.c ****     unsigned long value;
 581:App/Src/fault_command.c **** 
 582:App/Src/fault_command.c ****     cursor = FaultCommand_SkipSpaces(cursor);
 583:App/Src/fault_command.c ****     if ((cursor == NULL) || (*cursor == '\0'))
 584:App/Src/fault_command.c ****     {
 585:App/Src/fault_command.c ****       return HAL_ERROR;
 586:App/Src/fault_command.c ****     }
 587:App/Src/fault_command.c **** 
 588:App/Src/fault_command.c ****     value = strtoul(cursor, &endPtr, 16);
 589:App/Src/fault_command.c ****     if ((endPtr == cursor) || (value > 0xFFUL))
 590:App/Src/fault_command.c ****     {
 591:App/Src/fault_command.c ****       return HAL_ERROR;
 592:App/Src/fault_command.c ****     }
 593:App/Src/fault_command.c **** 
 594:App/Src/fault_command.c ****     data[index] = (uint8_t)value;
 595:App/Src/fault_command.c ****     cursor = endPtr;
 596:App/Src/fault_command.c ****   }
 597:App/Src/fault_command.c **** 
 598:App/Src/fault_command.c ****   return BspCan_SendClassic((uint32_t)id, 0U, data, (uint8_t)length);
 599:App/Src/fault_command.c **** }
