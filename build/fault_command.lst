 637:App/Src/fault_command.c ****   {
 638:App/Src/fault_command.c ****     return HAL_ERROR;
 639:App/Src/fault_command.c ****   }
 640:App/Src/fault_command.c **** 
 641:App/Src/fault_command.c ****   cursor = line + consumed;
 642:App/Src/fault_command.c ****   for (uint8_t index = 0U; index < length; index++)
 643:App/Src/fault_command.c ****   {
 644:App/Src/fault_command.c ****     char *endPtr;
 645:App/Src/fault_command.c ****     unsigned long value;
 646:App/Src/fault_command.c **** 
 647:App/Src/fault_command.c ****     cursor = FaultCommand_SkipSpaces(cursor);
