 607:App/Src/fault_command.c **** static HAL_StatusTypeDef FaultCommand_ParseCanSendText(const char *line)
 608:App/Src/fault_command.c **** {
 609:App/Src/fault_command.c ****   unsigned long id;
 610:App/Src/fault_command.c ****   unsigned int length;
 611:App/Src/fault_command.c ****   int consumed = 0;
 612:App/Src/fault_command.c ****   const char *cursor;
 613:App/Src/fault_command.c ****   uint8_t data[BSP_CAN_MAX_DATA_LEN] = {0};
 614:App/Src/fault_command.c **** 
 615:App/Src/fault_command.c ****   if (sscanf(line, "can send %lx %u %n", &id, &length, &consumed) < 2)
 616:App/Src/fault_command.c ****   {
 617:App/Src/fault_command.c ****     return HAL_ERROR;
 618:App/Src/fault_command.c ****   }
 619:App/Src/fault_command.c **** 
 620:App/Src/fault_command.c ****   if ((id > 0x7FFUL) || (length > BSP_CAN_MAX_DATA_LEN))
 621:App/Src/fault_command.c ****   {
 622:App/Src/fault_command.c ****     return HAL_ERROR;
 623:App/Src/fault_command.c ****   }
 624:App/Src/fault_command.c **** 
 625:App/Src/fault_command.c ****   cursor = line + consumed;
 626:App/Src/fault_command.c ****   for (uint8_t index = 0U; index < length; index++)
 627:App/Src/fault_command.c ****   {
 628:App/Src/fault_command.c ****     char *endPtr;
 629:App/Src/fault_command.c ****     unsigned long value;
 630:App/Src/fault_command.c **** 
 631:App/Src/fault_command.c ****     cursor = FaultCommand_SkipSpaces(cursor);
 632:App/Src/fault_command.c ****     if ((cursor == NULL) || (*cursor == '\0'))
 633:App/Src/fault_command.c ****     {
 634:App/Src/fault_command.c ****       return HAL_ERROR;
 635:App/Src/fault_command.c ****     }
 636:App/Src/fault_command.c **** 
 637:App/Src/fault_command.c ****     value = strtoul(cursor, &endPtr, 16);
 638:App/Src/fault_command.c ****     if ((endPtr == cursor) || (value > 0xFFUL))
 639:App/Src/fault_command.c ****     {
 640:App/Src/fault_command.c ****       return HAL_ERROR;
 641:App/Src/fault_command.c ****     }
 642:App/Src/fault_command.c **** 
 643:App/Src/fault_command.c ****     data[index] = (uint8_t)value;
 644:App/Src/fault_command.c ****     cursor = endPtr;
 645:App/Src/fault_command.c ****   }
 646:App/Src/fault_command.c **** 
 647:App/Src/fault_command.c ****   return BspCan_SendClassic((uint32_t)id, 0U, data, (uint8_t)length);
 648:App/Src/fault_command.c **** }
